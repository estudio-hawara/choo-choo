{
  "name": "@choo-choo/core",
  "version": "0.2.1",
  "description": "IR, manual builder and SVG renderer for choo-choo railroad diagrams.",
  "keywords": ["railroad", "railroad-diagram", "syntax-diagram", "svg", "ebnf", "ir", "renderer"],
  "author": "Estudio Hawara <carlos.capote@hawara.es>",
  "license": "MIT",
  "homepage": "https://estudio-hawara.github.io/choo-choo",
  "bugs": {
    "url": "https://github.com/estudio-hawara/choo-choo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estudio-hawara/choo-choo.git",
    "directory": "packages/core"
  },
  "type": "module",
  "sideEffects": ["./styles.css"],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./styles.css"
  },
  "files": ["dist", "src", "styles.css"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./styles.css": "./styles.css"
    }
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
