{
  "name": "@choo-choo/astro",
  "version": "0.0.0",
  "description": "Astro binding for choo-choo: the <ChooChoo> .astro component, SSR-only.",
  "keywords": ["railroad", "railroad-diagram", "syntax-diagram", "astro", "svg"],
  "author": "Estudio Hawara <carlos.capote@hawara.es>",
  "license": "MIT",
  "homepage": "https://estudio-hawara.github.io/choo-choo",
  "bugs": {
    "url": "https://github.com/estudio-hawara/choo-choo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estudio-hawara/choo-choo.git",
    "directory": "packages/astro"
  },
  "type": "module",
  "sideEffects": ["./styles.css"],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "astro": "./src/ChooChoo.astro",
      "default": "./src/ChooChoo.astro"
    },
    "./styles.css": "./styles.css"
  },
  "files": ["src", "styles.css"],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@choo-choo/core": "workspace:*"
  },
  "peerDependencies": {
    "astro": "^4 || ^5"
  },
  "devDependencies": {
    "astro": "^5.0.0",
    "typescript": "^5.6.3"
  }
}
