{
  "name": "@choo-choo/react",
  "version": "0.0.0",
  "description": "React binding for choo-choo: the <ChooChoo> component, SSR-safe and hook-free.",
  "keywords": ["railroad", "railroad-diagram", "syntax-diagram", "react", "svg"],
  "author": "Estudio Hawara <carlos.capote@hawara.es>",
  "license": "MIT",
  "homepage": "https://estudio-hawara.github.io/choo-choo",
  "bugs": {
    "url": "https://github.com/estudio-hawara/choo-choo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/estudio-hawara/choo-choo.git",
    "directory": "packages/react"
  },
  "type": "module",
  "sideEffects": ["./styles.css"],
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./styles.css"
  },
  "files": ["dist", "src", "styles.css"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./styles.css": "./styles.css"
    }
  },
  "dependencies": {
    "@choo-choo/core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@choo-choo/parser-ebnf": "workspace:*",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "happy-dom": "^15.11.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
