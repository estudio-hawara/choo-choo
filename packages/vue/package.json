{
  "name": "@choo-choo/vue",
  "version": "0.0.0",
  "description": "Vue 3 binding for choo-choo: the <ChooChoo> component, SSR-safe and hook-free.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./styles.css": "./styles.css"
  },
  "files": ["dist", "src", "styles.css"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      },
      "./styles.css": "./styles.css"
    }
  },
  "dependencies": {
    "@choo-choo/core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.3 || ^3.4 || ^3.5"
  },
  "devDependencies": {
    "@choo-choo/parser-ebnf": "workspace:*",
    "@vue/server-renderer": "^3.5.0",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^15.11.6",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "vue": "^3.5.0"
  }
}
